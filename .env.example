# Copy this file to .env and fill in any values needed.
# The scaffold uses no external API keys by default but everything runs locally via Ollama.

# Server
PORT=8080

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# This is only needed if you swap Ollama for Groq (TODO: Project swap exercise)
# GROQ_API_KEY=your_key_here
# GROQ_MODEL=llama-3.1-8b-instant